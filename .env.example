# Copy to .env and adjust. All of these are optional: the defaults in
# config/settings.py are sensible for a 12GB single-GPU box.

# --- Model ---
# LLM_MODEL=Qwen/Qwen3-8B
# ENABLE_THINKING=false
# LORA_ADAPTER_PATH=

# --- Retrieval ablation switches ---
# USE_HYDE=true
# USE_HYBRID=true
# USE_RERANKER=true

# --- VRAM ---
# Set true to push embedder + reranker to CPU while the LLM holds the GPU.
# LOW_VRAM_MODE=false
# EMBEDDING_DEVICE=cuda
# RERANKER_DEVICE=cuda

# --- GROBID ---
# GROBID_URL=http://localhost:8070

# --- Offline LLM judge (eval only) ---
# JUDGE_MODEL=
# JUDGE_API_KEY=
